<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Manual do Usuário</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/sidebar.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <style>
        .pdf-container {
            width: 100%;
            height: calc(100vh - 150px);
            margin-top: 20px;
            border: 2px solid #2e3134;
            border-radius: 12px;
            background: #080808;
        }
        
        .pdf-container iframe {
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 12px;
        }
        
        .pdf-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .pdf-title {
            font-size: 1.2rem;
            color: var(--primary-red);
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        
        .btn-download {
            padding: 10px 20px;
            background: transparent;
            border: 2px solid var(--primary-red);
            color: var(--primary-red);
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
        }
        
        .btn-download:hover {
            background: var(--primary-red);
            color: white;
        }
    </style>
</head>
<body class="dash-body">
    <%- include('partials/barAluno') %>
    
    <div class="main-layout">
        <header class="dash-header">
            <div class="header-left">
                <h1>
                    Manual do Aluno
                </h1>
            </div>
            
            <div class="header-user">
                <div class="user-profile-group">
                    <div class="user-details">
                        <span class="user-name"><strong><%= user %></strong></span>
                    </div>
                </div>
                <div class="header-actions">
                    <%- include('./partials/notificacoes', { notificacaoClasse: 'header-icon' }) %>
                     
                </div>
            </div>
        </header>
        
        <div class="pdf-header">
            <a href="/PDF/manualDoAluno.pdf" download class="btn-secondary-dash">
                <i class="fas fa-download"></i> BAIXAR PDF
            </a>
        </div>
        
        <div class="pdf-container">
            <iframe src="/PDF/manualDoAluno.pdf"></iframe>
        </div>
    </div>
</body>
</html>