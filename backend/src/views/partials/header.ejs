<div id="infoModal" class="modal-new-overlay">
    <div class="modal-new-card">
        <button class="modal-new-close" onclick="closeModal()">
            <i class="fas fa-times"></i>
        </button>

        <div class="modal-new-header" style="justify-content: center;align-items: center;display: flex;flex-direction: column;">
            <img src="/IMG/logo3-white.png" alt="AnalisAI" class="modal-new-logo">
            <div class="version-badge">Versão 1.0.4</div>
        </div>

        <div class="modal-new-body">
            <p class="modal-new-text">
                Plataforma avançada para gestão de competências e análise de desempenho educacional. 
                Desenvolvida para facilitar a visualização de dados e tomada de decisão pedagógica.
            </p>
            
            <div class="modal-new-divider"></div>
            
            <div class="modal-new-info-grid">
                <div class="info-item">
                    <span>Ambiente</span>
                    <p>Produção</p>
                </div>
                <div class="info-item">
                    <span>Atualização</span>
