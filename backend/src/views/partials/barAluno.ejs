        <div class="divider"></div>

        <a href="/aluno" class="side-link">
            <div class="icon-box"><i class="fas fa-home"></i></div>
            <span class="link-text">Início</span>
            <div class="active-indicator"></div>
        </a>

        <a href="/aluno/competencias" class="side-link">
            <div class="icon-box"><i class="fa-solid fa-medal"></i></div>
            <span class="link-text">Competências</span>
            <div class="active-indicator"></div>
        </a>

        <a href="/aluno/tarefas" class="side-link">
            <div class="icon-box"><i class="fa-solid fa-tasks"></i></div>
            <span class="link-text">Tarefas</span>
            <div class="active-indicator"></div>
        </a>

        <a href="/aluno/evolucao" class="side-link">
            <div class="icon-box"><i class="fas fa-chart-line"></i></div>
            <span class="link-text">Evolução</span>
            <div class="active-indicator"></div>
        </a>
    </div>
    
    <div class="sidebar-bottom">
        <a href="/aluno/config" class="side-link">
            <div class="icon-box"><i class="fas fa-cog"></i></div>
