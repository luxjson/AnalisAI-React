<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <style>
        body.dash-body {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-wrapper {
            width: 100%;
            max-width: 450px;
            animation: fadeInPage 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .login-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 25px;
            padding: 40px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        }

        .login-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-logo img {
            height: 50px;
            transition: var(--transition-smooth);
        }
        .login-tabs {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
            border-bottom: 1px solid var(--border-color);
        }

        .login-tab {
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 15px 0;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            transition: 0.3s;
            border-bottom: 3px solid transparent;
        }

        .login-tab.active.professor { color: white; border-bottom-color: var(--primary-red); }
        .login-tab.active.aluno { color: white; border-bottom-color: var(--color-apto); }

        .input-group {
            margin-bottom: 20px;
        }

        .input-group input {
            width: 100%;
            background: #121212;
            border: 1px solid var(--border-color);
            padding: 15px;
            border-radius: 12px;
            color: white;
            font-family: var(--font-family);
            transition: var(--transition-smooth);
        }

        .input-group input:focus {
            border-color: var(--primary-red);
            background: #181818;
        }

        .input-group-aluno input:focus {
            border-color: var(--color-apto);
        }

        .btn-login {
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            border: none;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--transition-smooth);
            margin-top: 10px;
        }

        .btn-professor { background: var(--primary-red); color: white; }
        .btn-professor:hover { background: var(--primary-red-hover); transform: translateY(-2px); }

        .btn-aluno { background: var(--color-apto); color: white; }
        .btn-aluno:hover { opacity: 0.9; transform: translateY(-2px); }

        .login-form { display: none; }
        .login-form.active { display: block; animation: fadeInPage 0.4s ease; }

        .link-esqueci {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: var(--text-gray);
            text-decoration: none;
            font-size: 0.85rem;
        }

        .link-esqueci:hover { color: white; }

        .info-box-login {
            background: rgba(33, 115, 70, 0.1);
            border: 1px solid var(--color-apto);
            color: var(--color-apto);
            padding: 12px;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 20px;
            text-align: center;
        }

        .alert-box {
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 0.85rem;
            text-align: center;
        }
        .error { background: rgba(255, 1, 1, 0.1); border: 1px solid var(--primary-red); color: var(--primary-red); }
        .success { background: rgba(33, 115, 70, 0.1); border: 1px solid var(--color-apto); color: var(--color-apto); }
    </style>
</head>
<body class="dash-body">

    <div class="login-wrapper">
        
        <div style="margin-bottom: 20px;">
            <a href="/" class="btn-secondary-dash" style="text-decoration: none;">
                <i class="fas fa-undo-alt"></i> VOLTAR
            </a>
        </div>

        <div class="login-card">
            <div class="login-logo">
                <img src="/IMG/logo3-white.png" alt="AnalisAI" id="logoimg">
            </div>

            <% if (error_msg && error_msg.length > 0) { %>
                <div class="alert-box error"><i class="fas fa-exclamation-circle"></i> <%= error_msg %></div>
            <% } %>
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="alert-box success"><i class="fas fa-check-circle"></i> <%= success_msg %></div>
            <% } %>

            <div class="login-tabs">
                <button class="login-tab professor <%= tipo === 'professor' ? 'active' : '' %>" onclick="switchTab('professor')">PROFESSOR</button>
                <button class="login-tab aluno <%= tipo === 'aluno' ? 'active' : '' %>" onclick="switchTab('aluno')">ALUNO</button>
            </div>

            <div class="login-form professor <%= tipo === 'professor' ? 'active' : '' %>" id="professorForm">
                <form action="/login/professor" method="POST" style="display: flex;flex-direction: column;">
                    <div class="input-group">
                        <input type="text" name="usuario" placeholder="E-MAIL INSTITUCIONAL" oninput="this.value = this.value.toLowerCase()" required>
                    </div>
                    <div class="input-group">
                        <input type="password" name="senha" placeholder="SENHA"  required>
                    </div>
                    <button type="submit" class="btn-secondary-dash" style="justify-content: center;">ENTRAR NO SISTEMA</button>
                </form>
                <a href="/esquecisenha" class="link-esqueci">Esqueci minha senha</a>
            </div>

            <div class="login-form aluno <%= tipo === 'aluno' ? 'active' : '' %>" id="alunoForm">
                <div class="info-box-login">
                    <i class="fas fa-info-circle"></i> Use sua matrícula ou e-mail cadastrado
                </div>
                <form action="/login/aluno" method="POST" style="display: flex;flex-direction: column;">
                    <div class="input-group input-group-aluno">
                        <input type="text" name="matricula" placeholder="MATRÍCULA" oninput="this.value = this.value.toLowerCase()">
                    </div>
                    <div class="input-group input-group-aluno">
                        <input type="email" name="email" oninput="this.value = this.value.toLowerCase()" placeholder="E-MAIL">
                    </div>
                    <div class="input-group input-group-aluno">
                        <input type="password" name="senha" placeholder="SENHA" required>
                    </div>
                    <button type="submit" class="btn-secondary-dash" style="justify-content: center;">ENTRAR NO SISTEMA</button>
                </form>
            </div>
        </div>

        <footer style="margin-top: 30px; text-align: center;">
            <a href="/termos" class="btn-secondary-dash" style="font-size: 0.7rem; border: none; background: transparent;">
                TERMOS DE SERVIÇO
            </a>
        </footer>
    </div>

    <script>
        function switchTab(tipo) {
            const tabs = document.querySelectorAll('.login-tab');
            const forms = document.querySelectorAll('.login-form');
            const logo = document.getElementById('logoimg');
            
            tabs.forEach(tab => tab.classList.remove('active', 'professor', 'aluno'));
            forms.forEach(form => form.classList.remove('active'));
            
            if (tipo === 'professor') {
                const tab = document.querySelector('.login-tab:nth-child(1)');
                tab.classList.add('active', 'professor');
                document.getElementById('professorForm').classList.add('active');
                logo.src = '/IMG/logo3-white.png';
            } else {
                const tab = document.querySelector('.login-tab:nth-child(2)');
                tab.classList.add('active', 'aluno');
                document.getElementById('alunoForm').classList.add('active');
                logo.src = '/IMG/logo3-green.png';
            }
        }
    </script>
</body>
</html>