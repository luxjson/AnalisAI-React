<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Equipe</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <style>
        body.dash-body {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            min-height: 100vh;
        }

        .login-wrapper {
            width: 100%;
            max-width: 500px;
            animation: fadeInPage 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .login-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 25px;
            padding: 45px 40px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            position: relative;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0; left: 50%;
            transform: translateX(-50%);
            width: 80px; height: 4px;
            background: var(--primary-red);
            border-radius: 0 0 10px 10px;
        }

        .team-title {
            text-align: center;
            font-size: 1.3rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 35px;
            color: white;
        }

        .team-group {
            margin-bottom: 25px;
        }

        .team-label {
            display: block;
            font-size: 0.7rem;
            color: var(--text-gray);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .team-box {
            background: #121212;
            border: 1px solid var(--border-color);
            padding: 15px 20px;
            border-radius: 12px;
            transition: var(--transition-smooth);
        }

        .team-box:hover {
            border-color: #444;
        }

        .team-box p {
            color: white;
            font-size: 0.9rem;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .team-box p:last-child {
            margin-bottom: 0;
        }

        .team-box i {
            color: var(--primary-red);
            font-size: 0.8rem;
        }

        .btn-full {
            width: 100%;
            padding: 16px;
            background: var(--primary-red);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: var(--transition-smooth);
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
        }

        .btn-full:hover {
            background: var(--primary-red-hover);
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="dash-body">

    <div class="login-wrapper">
        <div style="margin-bottom: 20px;">
            <a href="javascript:history.back()" class="btn-secondary-dash" style="text-decoration: none;">
                <i class="fas fa-undo-alt"></i> VOLTAR AO PAINEL
            </a>
        </div>

        <div class="login-card">
            <div style="text-align: center; margin-bottom: 30px;">
                <img src="/IMG/logo3-white.png" alt="AnalisAI" style="height: 40px;">
            </div>

            <h2 class="team-title">Time de Desenvolvimento</h2>

            <div class="team-content">
                <div class="team-group">
                    <span class="team-label">FRONT-END</span>
                    <div class="team-box">
                        <p><i class="fas fa-user-edit"></i> LUCAS EDUARDO DUARTE PEREIRA</p>
                        <p><i class="fas fa-user-edit"></i> ELLEFER FERNANDA BOVAROTI RIZZO</p>
                    </div>
                </div>
                <div class="team-group">
                    <span class="team-label">BACK-END</span>
                    <div class="team-box">
                        <p><i class="fas fa-terminal"></i> LUCAS EDUARDO DUARTE PEREIRA</p>
                        <p><i class="fas fa-terminal"></i> ISABELLA LI AFFA SANCHES</p>
                    </div>
                </div>
                <div class="team-group">
                    <span class="team-label">BANCO DE DADOS</span>
                    <div class="team-box">
                        <p><i class="fas fa-database"></i> ISABELLA LI AFFA SANCHES</p>
                        <p><i class="fas fa-database"></i> LUIZ OTÁVIO DA SILVA MATTARUGO</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>