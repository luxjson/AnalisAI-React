<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Solicitações de Senha</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/sidebar.css">
    <link rel="stylesheet" href="/CSS/edit.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <style>
        .solicitacoes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .solicitacao-card {
            background: #18181b;
            border: 2px solid #2e3134;
            border-radius: 15px;
            padding: 20px;
        }
        
        .solicitacao-nome {
            color: #fff;
            font-size: 1rem;
            margin-bottom: 5px;
        }
        
        .solicitacao-email {
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 5px;
        }
        
        .solicitacao-data {
            color: #666;
            font-size: 0.8rem;
            margin-bottom: 15px;
        }
        
        .solicitacao-acoes {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }
        
        .btn-aprovar {
            flex: 1;
            background: #217346;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }
        
        .btn-aprovar:hover {
            background: #2a8e4f;
        }
        
        .btn-rejeitar {
            flex: 1;
            background: #ff0101;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }
        
        .btn-rejeitar:hover {
            background: #ff3333;
        }
        
        .modal-pequeno {
            max-width: 400px;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: #18181b;
            border: 2px solid #2e3134;
            border-radius: 20px;
        }

        
.a {
    background: transparent;
    border: 2px solid #2e3134;
    color: white;
    padding: 12px 25px;
    cursor: pointer;
    border-radius: 12px;
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.a:hover a {
    color: white;
}

.a:hover {
    border-color: #ff0000;
    color: var(--text-white);
    background: rgba(115, 33, 33, 0.205);
}

.a i {
    font-size: 1rem;
    opacity: 0.8;
}

.b {
    background: transparent;
    border: 2px solid #2e3134;
    color:white;
    padding: 12px 25px;
    cursor: pointer;
    border-radius: 12px;
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.b:hover a {
    color: white;
}

.b:hover {
    border-color: #217346;
    color: var(--text-white);
    background: rgba(33, 115, 70, 0.05);
}

.b i {
    font-size: 1rem;
    opacity: 0.8;
}
    </style>
</head>
<body class="dash-body">
    <%- include('../partials/barProfessor') %>
    
    <div class="main-layout">
        <header class="dash-header">
            <div class="header-left">
                <h1>
                    Solicitações de Senha
                </h1>
            </div>
            
            <div class="header-user">
                <div class="user-profile-group">
                    <div class="user-details">
                        <span class="user-name"><strong><%= user %></strong></span>
                        <span class="user-role" style="color: #888888;"><strong><%= userCargo %></strong></span>
                    </div>
                </div>
                <div class="header-actions">
                    <%- include('../partials/notificacoes', { notificacaoClasse: 'header-icon' }) %>
                     
                </div>
            </div>
        </header>
        
        <main class="dash-content">
            <% if (solicitacoes.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-inbox" style="font-size: 3rem; color: #333;"></i>
                    <h3 style="color: #666; margin-top: 15px;">Nenhuma solicitação pendente</h3>
                </div>
            <% } else { %>
                <div class="solicitacoes-grid">
                    <% solicitacoes.forEach(s => { %>
                        <div class="solicitacao-card">
                            <div class="solicitacao-nome">
                                <i class="fas fa-user"></i> <%= s.nome %>
                            </div>
                            <div class="solicitacao-email">
                                <i class="fas fa-envelope"></i> <%= s.email %>
                            </div>
                            <div class="solicitacao-data">
                                <i class="far fa-clock"></i> 
                                <%= new Date(s.data_solicitacao).toLocaleString('pt-BR') %>
                            </div>
                            <div class="solicitacao-acoes">
                                <button class="btn-secondary-dash" onclick="abrirModalAprovar(<%= s.id %>, '<%= s.nome %>')">
                                    <i class="fas fa-check"></i> APROVAR
                                </button>
                                <button class="btn-secondary-dash" onclick="abrirModalRejeitar(<%= s.id %>, '<%= s.nome %>')">
                                    <i class="fas fa-times"></i> REJEITAR
                                </button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </main>
    </div>
    
    <div id="modalAprovar" class="modal-overlay">
        <div class="modal-content modal-pequeno">
            <button class="close-btn" onclick="fecharModal('modalAprovar')">
                <i class="fas fa-times-circle"></i>
            </button>
            <h2 class="section-title-2">APROVAR SOLICITAÇÃO</h2>
            <form action="" method="POST" id="formAprovar">
                <div class="filter-options">
                    <p style="color: #888; margin-bottom: 15px;" id="nomeAprovar"></p>
                    <label>NOVA SENHA</label>
                    <input type="password" name="nova_senha" class="filter-input" required minlength="6">
                    <button type="submit" class="btn-secondary-dash" style="margin-top: 20px; justify-content: center;">REDEFINIR SENHA</button>
                </div>
            </form>
        </div>
    </div>
    
    <div id="modalRejeitar" class="modal-overlay">
        <div class="modal-content modal-pequeno">
            <button class="close-btn" onclick="fecharModal('modalRejeitar')">
                <i class="fas fa-times-circle"></i>
            </button>
            <h2 class="section-title-2">REJEITAR SOLICITAÇÃO</h2>
            <form action="" method="POST" id="formRejeitar">
                <div class="filter-options">
                    <p style="color: #888; margin-bottom: 15px;" id="nomeRejeitar"></p>
                    <label>MOTIVO (opcional)</label>
                    <textarea name="motivo" class="filter-input" rows="3" placeholder="Por que está rejeitando?"></textarea>
                    <button type="submit" class="btn-secondary-dash" style="margin-top: 20px; justify-content: center;">REJEITAR</button>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        function abrirModalAprovar(id, nome) {
            document.getElementById('formAprovar').action = `/dashboard/solicitacoes-senha/aprovar/${id}`;
            document.getElementById('nomeAprovar').innerHTML = `<strong>${nome}</strong>`;
            document.getElementById('modalAprovar').style.display = 'flex';
        }
        
        function abrirModalRejeitar(id, nome) {
            document.getElementById('formRejeitar').action = `/dashboard/solicitacoes-senha/rejeitar/${id}`;
            document.getElementById('nomeRejeitar').innerHTML = `<strong>${nome}</strong>`;
            document.getElementById('modalRejeitar').style.display = 'flex';
        }
        
        function fecharModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }
    </script>
</body>
</html>