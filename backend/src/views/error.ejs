<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Erro</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/sidebar.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <link rel="stylesheet" href="/CSS/edit.css">
    
</head>
<body class="dash-body">

    <% if (userCargo === 'Professor' || userCargo === 'Admin') { %>
    <%- include('partials/barProfessor') %>
    <% } else { %>
        <%- include('partials/barAluno') %>
    <% } %>

    <div class="main-layout">
        <header class="dash-header">
            <div class="header-left">
                <h1>
                    <%= titulo || 'OPS! ALGO DEU ERRADO' %>
                </h1>
            </div>
            
            <div class="header-user">
                <div class="user-profile-group">
                    <div class="user-details">
                        <span class="user-name"><strong><%= user %></strong></span>
                        <span class="user-role" style="color: #888888;"><strong><%= userCargo %></strong></span>
                    </div>
                </div>
                <div class="header-actions">
                    <%- include('./partials/notificacoes', { notificacaoClasse: 'header-icon' }) %>
                     
                </div>
            </div>
        </header>

        <main class="dash-content" style="display: flex; align-items: center; justify-content: center; min-height: 60vh;">
            <div class="modal-content" style="max-width: 500px; text-align: center;">
                <div class="modal-icon-warning" style="font-size: 4rem; color: var(--primary-red); margin-bottom: 20px;">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                
                <h2 class="modal-title-warning" style="font-size: 1.5rem; margin-bottom: 15px;">
                    <%= titulo || 'OPS! ALGO DEU ERRADO' %>
                </h2>
                
                
                <p class="modal-text-warning" style="color: #888; font-size: 1rem; line-height: 1.6; margin-bottom: 30px;">
                    <%= mensagem || 'Ocorreu um erro inesperado. Tente novamente.' %>
                </p>
                
                <% if (erroDetalhe) { %>
                    <div style="background: #1a1a1a; padding: 15px; border-radius: 10px; margin-bottom: 30px; text-align: left; border: 2px solid #333;">
                        <p style="color: #ff0101; font-size: 0.85rem; margin-bottom: 5px;">Detalhes:</p>
                        <p style="color: #888; font-size: 0.8rem; font-family: monospace;"><%= erroDetalhe %></p>
                    </div>
                <% } %>
                
                <div class="modal-actions" style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                    <a href="javascript:history.back()" class="btn-secondary-dash" style="text-decoration: none; height: 55px;">
                        <i class="fas fa-arrow-left"></i> VOLTAR
                    </a>
                    
                    <% if (isAdmin) { %>
                        <a href="javascript:void()" onclick="openEraseModal()" class="btn-secondary-dash" style="text-decoration: none; height: 55px;">
                            <i class="fas fa-database"></i> LIMPAR BASE DE DADOS (ALUNOS)
                        </a>
                    <% } %>
                </div>
            </div>
        </main>

        <footer class="dash-footer">
            <div class="footer-credits" style="width: 100%; text-align: center;">
                <p>© 2026 AnalisAI</p>
            </div>
        </footer>
    </div>

    <% if (isAdmin) { %>
    <div id="eraseAllModal" class="modal-overlay">
        <div class="modal-content modal-small">
            
            <button class="close-btn" onclick="closeEraseModal()"><i class="fas fa-times-circle"></i></button>
            <div class="modal-icon-warning">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h2 class="modal-title-warning">APAGAR TUDO?</h2>
            <p class="modal-text-warning">
                Esta ação irá remover <strong>TODOS</strong> os alunos, notas e competências atribuídas.<br>
                As competências padrão do sistema serão mantidas.<br>
                <span style="color: #ff0101;">Esta operação não pode ser desfeita.</span>
            </p>
            <div class="modal-actions">
                <form action="/dashboard/erase-all" method="POST">
                    <button type="submit" class="btn-secondary-dash" style="justify-content: center; height: 50px; width: 300px;">
                        <span class="material-symbols-outlined">delete</span> SIM, APAGAR TUDO
                    </button>
                </form>
                <button onclick="closeEraseModal()" class="btn-secondary-dash" style="margin-left: 9px; justify-content: center;height: 50px; width: 300px;">
                    CANCELAR
                </button>
            </div>
        </div>
    </div>
    <% } %>

    <script>
        function openEraseModal() {
            document.getElementById('eraseAllModal').style.display = 'flex';
        }

        function closeEraseModal() {
            document.getElementById('eraseAllModal').style.display = 'none';
        }
    </script>
</body>
</html>